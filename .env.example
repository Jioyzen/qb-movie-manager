# QB Movie Manager - 环境变量配置
# 复制此文件为 .env 并填入你的实际配置
# .env 文件不会被提交到 Git 仓库

# ─── qBittorrent ────────────────────────────────────────────
QB_HOST=192.168.1.100
QB_PORT=8085
QB_USERNAME=admin
QB_PASSWORD=

# ─── TMDB ───────────────────────────────────────────────────
# 从 https://www.themoviedb.org/settings/api 获取
TMDB_API_KEY=
TMDB_RATE_LIMIT=0.2

# ─── SMB 挂载（MediaInfo 深度分析需要） ─────────────────────
SMB_HOST=192.168.1.100
SMB_SHARE=downloads
SMB_USERNAME=
SMB_PASSWORD=
SMB_MOUNT_POINT=/mnt/qb_downloads
QB_DOWNLOAD_PREFIX=/downloads